{
  "manifest_version": 3,
  "name": "Paper Reader",
  "version": "1.0.0",
  "description": "Locally extracts citation references and displays links as hover tooltips on scientific PDFs.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "unlimitedStorage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paper Reader",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*.pdf",
        "https://*/*.pdf",
        "file:///*/*.pdf"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "tooltip.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdfjs/*",
        "extractor.js",
        "config.js",
        "pdf.worker.js",
        "tooltip.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
